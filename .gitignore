# Keep only site-related paths at repository root
/*

!/.gitignore
!/README.md
!/.github/
!/.github/**
!/.np/
!/.np/**
!/content/
!/content/**
!/media/
!/media/**

# Re-ignore local build outputs/caches inside allowed directories
/.notepub/
/.np/.notepub/
/.np/dist/
/.np/bin/

# Editor/system noise
**/.DS_Store
*.log
*.swp
.idea/
.vscode/
.obsidian/
.env
.env.*
